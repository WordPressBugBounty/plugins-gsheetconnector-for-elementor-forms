msgstr ""
"यह प्लगइन को आपके फॉर्म डेटा को Google Sheets के साथ सुरक्षित रूप से समन्वयित करने की अनुमति "
"देता है।"

msgid ""
"<p class=\"fw-400 text-dark\"><strong>Google Drive</strong> and <strong>Google "
"Sheets</strong> permissions were not granted during authentication with Google.</"
"p>\n"
"                                        <p class=\"fw-400 text-"
"dark\"><strong>Refer to Step 4 in the Connection Guide shown alongside.</"
"strong><br> Then, deactivate the connection and re-authorize it, ensuring both "
"Google Drive and Google Sheets permissions are enabled.</p>"
msgstr ""
"<p class=\"fw-400 text-dark\"><strong>Google Drive</strong> और <strong>Google "
"Sheets</strong> की अनुमतियाँ Google के साथ प्रमाणीकरण के दौरान नहीं दी गईं।</p>\n"
"                                        <p class=\"fw-400 text-dark\"><strong>साथ "
"में दिखाए गए कनेक्शन गाइड में चरण 4 देखें।</strong><br> फिर, कनेक्शन को निष्क्रिय करें और इसे फिर "
"से अधिकृत करें, यह सुनिश्चित करते हुए कि Google Drive और Google Sheets की अनुमतियाँ सक्षम हैं।</"
"p>"

msgid "Connected"
msgstr "जुड़ा हुआ"

msgid "Connect Your Google Account"
msgstr "अपने Google खाते को कनेक्ट करें"

msgid ""
"Securely link your Google account to start syncing form entries automatically."
msgstr ""
"अपने Google खाते को सुरक्षित रूप से लिंक करें ताकि फॉर्म प्रविष्टियाँ स्वचालित रूप से समन्वयित हो "
"सकें।"

msgid "Client Token"
msgstr "क्लाइंट टोकन"

msgid "Save Client Token"
msgstr "क्लाइंट टोकन सहेजें"

