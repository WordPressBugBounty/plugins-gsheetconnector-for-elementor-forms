msgid ""
"Displays the form and feed information used for Google Sheets "
"synchronization."
msgstr ""
"Muestra la información del formulario y de la alimentación utilizada para "
"la sincronización de Google Sheets."

msgid "Form ID"
msgstr "ID del formulario"

msgid "Timestamp"
msgstr "Marca de tiempo"

msgid ""
"Manual connect your Elementor Form with Google Sheets by entering the Sheet "
"Name, Sheet ID, Tab Name, and Tab ID. This ensures that form submissions "
"are stored directly in your chosen Google Sheet."
msgstr ""
"Conecta manualmente tu formulario de Elementor con Google Sheets ingresando "
"el nombre de la hoja, el ID de la hoja, el nombre de la pestaña y el ID de "
"la pestaña. Esto asegura que las presentaciones del formulario se almacenen "
"directamente en tu hoja de Google elegida."

msgid ""
"Go to your Google account, open Google Sheets, and select or create the "
"sheet you want to connect."
msgstr ""
"Ve a tu cuenta de Google, abre Google Sheets y selecciona o crea la hoja "
"que deseas conectar."

msgid "You can get the Sheet ID from your Google Sheet URL."
msgstr "Puedes obtener el ID de la hoja desde la URL de tu hoja de Google."

msgid ""
"Open your Google Sheet and copy the tab name shown at the bottom where you "
"want entries stored."
msgstr ""
"Abre tu hoja de Google y copia el nombre de la pestaña que se muestra en la "
"parte inferior donde deseas que se almacenen las entradas."

msgid "You can get the Tab ID from your Google Sheet URL after gid=."
msgstr ""
"Puedes obtener el ID de la pestaña desde la URL de tu hoja de Google "
"después de gid=."

