msgid "Google Sheets Data Sync"
msgstr "ગૂગલ શીટ્સ ડેટા સિંક"

msgid ""
"Easily sync past form submissions to your connected Google Sheet. Choose a date "
"range and ensure your spreadsheet stays complete and up to date."
msgstr ""
"તમારા જોડાયેલા ગૂગલ શીટમાં ભૂતકાળની ફોર્મ સબમિશન સરળતાથી સિંક કરો. તારીખ શ્રેણી પસંદ કરો અને "
"ખાતરી કરો કે તમારી સ્પ્રેડશીટ સંપૂર્ણ અને અપડેટ રહે."

msgid "Close"
msgstr "બંધ કરો"

msgid "About GSheetConnector"
msgstr "GSheetConnector વિશે"

msgid "Built by Experts. Trusted by Thousands."
msgstr "વિશેષજ્ઞો દ્વારા બનાવેલ. હજારો દ્વારા વિશ્વસનીય."

msgid ""
"Led by experienced developers and powered by a passionate team, GSheetConnector "
"helps WordPress users automate their workflows with confidence."
msgstr ""
"અનુભવી ડેવલપર્સ દ્વારા નેતૃત્વ અને ઉત્સાહી ટીમ દ્વારા શક્તિશાળી, GSheetConnector વોર્ડપ્રેસ "
"વપરાશકર્તાઓને તેમના કાર્યપ્રવાહને આત્મવિશ્વાસ સાથે સ્વચાલિત કરવામાં મદદ કરે છે."

msgid ""
"We focus on building tools that are fast, secure, and easy to use - so you can "
"spend less time managing data."
msgstr ""
"અમે એવા સાધનો બનાવવામાં ધ્યાન કેન્દ્રિત કરીએ છીએ જે ઝડપી, સુરક્ષિત અને ઉપયોગમાં સરળ હોય - જેથી "
"તમે ડેટા વ્યવસ્થાપનમાં ઓછો સમય વિતાવી શકો."

msgid "Meet Our Core Team"
msgstr "અમારી મુખ્ય ટીમને મળો"

msgid "Our Mission"
msgstr "અમારી મિશન"

msgid ""
"Our mission is to make form automation simple, secure, and reliable for every "
"WordPress user - from beginners to enterprise teams."
msgstr ""
"અમારી મિશન એ છે કે દરેક વોર્ડપ્રેસ વપરાશકર્તા માટે ફોર્મ ઓટોમેશનને સરળ, સુરક્ષિત અને વિશ્વસનીય "
"બનાવવું - શરુઆતથી એન્ટરપ્રાઇઝ ટીમો સુધી."

msgid "Fast & Reliable Data Sync"
msgstr "ઝડપી અને વિશ્વસનીય ડેટા સિંક"

msgid "100% Secure Authentication"
msgstr "100% સુરક્ષિત પ્રમાણપત્ર"

msgid "Real-Time Google Sheets Updates"
msgstr "વાસ્તવિક-સમય ગૂગલ શીટ્સ અપડેટ"

msgid "Easy Setup & Configuration"
msgstr "સરળ સેટઅપ અને રૂપરેખાંકન"

msgid "Dedicated Support Team"
msgstr "નિષ્ઠાવાન સપોર્ટ ટીમ"

msgid "Forms Successfully Synced"
msgstr "ફોર્મ સફળતાપૂર્વક સિંક કરાયા"

msgid "Trusted by Active Users"
msgstr "સક્રિય વપરાશકર્તાઓ દ્વારા વિશ્વસનીય"

msgid "Reliable Uptime"
msgstr "વિશ્વસનીય અપટાઇમ"

msgid "Dedicated Support"
msgstr "નિષ્ઠાવાન સપોર્ટ"

msgid "Add-ons & Extensions"
msgstr "એડ-ઓન્સ અને એક્સટેંશન્સ"

msgid ""
"Extend your Google Sheets integration with powerful add-ons. Install, manage, and "
"activate extensions to unlock advanced features."
msgstr ""
"તમારા ગૂગલ શીટ્સ ઇન્ટિગ્રેશનને શક્તિશાળી એડ-ઓન્સ સાથે વિસ્તારો. સ્થાપિત કરો, વ્યવસ્થાપિત કરો અને "
"વિસ્તરણોને સક્રિય કરો જેથી અદ્યતન સુવિધાઓ અનલોક થાય."

msgid "CF7 Google Sheet Connector"
msgstr "CF7 ગૂગલ શીટ કનેક્ટર"

msgid ""
"Easily connect Contact Form 7 to Google Sheets and automatically sync form "
"submissions in real-time. Every entry is instantly added to your selected "
"spreadsheet, helping you manage leads, inquiries, and customer data efficiently "
"without manual export."
msgstr ""
"સહેલાઈથી કોન્ટેક્ટ ફોર્મ 7 ને ગૂગલ શીટ્સ સાથે જોડો અને વાસ્તવિક-સમયમાં ફોર્મ સબમિશન આપોઆપ સિંક "
"કરો. દરેક પ્રવેશ તરત જ તમારી પસંદ કરેલી સ્પ્રેડશીટમાં ઉમેરવામાં આવે છે, જે તમને નેતૃત્વ, પૂછપરછ અને "
"ગ્રાહક ડેટાને કાર્યક્ષમ રીતે વ્યવસ્થાપિત કરવામાં મદદ કરે છે."

msgid "Install"
msgstr "સ્થાપિત કરો"

msgid "WPForms Google Sheet Connector"
msgstr "WPForms ગૂગલ શીટ કનેક્ટર"

msgid ""
"Integrate WPForms with Google Sheets and send form entries directly to your "
"spreadsheet automatically. Track leads, manage customer data, and streamline "
"reporting with seamless Google Sheets integration and real-time sync."
msgstr ""
"WPForms ને ગૂગલ શીટ્સ સાથે એકીકૃત કરો અને ફોર્મ પ્રવેશોને આપોઆપ તમારા સ્પ્રેડશીટમાં મોકલો. લીડ્સને "
"ટ્રેક કરો, ગ્રાહક ડેટાને સંચાલિત કરો, અને સરળ ગૂગલ શીટ્સ એકીકરણ અને વાસ્તવિક સમય સમન્વય સાથે "
"અહેવાલને સરળ બનાવો."

msgid "Gravity Forms Google Sheet Connector"
msgstr "ગ્રેવિટી ફોર્મ્સ ગૂગલ શીટ કનેક્ટર"

msgid ""
"Connect Gravity Forms to Google Sheets and automatically push form submissions to "
"your spreadsheet. Simplify data management, improve workflow automation, and keep "
"all entries organized in one secure location."
msgstr ""
"ગ્રેવિટી ફોર્મ્સને ગૂગલ શીટ્સ સાથે જોડો અને આપોઆપ ફોર્મ સબમિશન્સને તમારા સ્પ્રેડશીટમાં મોકલો. ડેટા "
"વ્યવસ્થાપનને સરળ બનાવો, વર્કફ્લો ઓટોમેશનમાં સુધારો, અને તમામ પ્રવેશોને એક સુરક્ષિત સ્થાનમાં ગોઠવો."

msgid "Ninja Forms Google Sheet Connector"
msgstr "નinja ફોર્મ્સ ગૂગલ શીટ કનેક્ટર"

msgid ""
"Automatically sync Ninja Forms submissions to Google Sheets with one-click "
"integration. Capture leads, monitor responses, and manage data efficiently with "
"instant spreadsheet updates and easy reporting."
msgstr ""
"નinja ફોર્મ્સ સબમિશન્સને ગૂગલ શીટ્સમાં એક ક્લિકના એકીકરણ સાથે આપોઆપ સમન્વયિત કરો. લીડ્સને કેચ "
"કરો, પ્રતિસાદોને મોનિટર કરો, અને તાત્કાલિક સ્પ્રેડશીટ અપડેટ્સ અને સરળ અહેવાલ સાથે ડેટાને અસરકારક "
"રીતે સંચાલિત કરો."

msgid "Forminator Forms Google Sheet Connector"
msgstr "ફોર્મિનેટર ફોર્મ્સ ગૂગલ શીટ કનેક્ટર"

msgid ""
"Integrate Forminator Forms with Google Sheets to automatically store form entries "
"in your spreadsheet. Eliminate manual data entry and ensure accurate, real-time "
"syncing for better data tracking and analysis."
msgstr ""
"ફોર્મિનેટર ફોર્મ્સને ગૂગલ શીટ્સ સાથે એકીકૃત કરો જેથી ફોર્મ પ્રવેશોને આપોઆપ તમારા સ્પ્રેડશીટમાં "
"સંગ્રહિત કરી શકાય. મેન્યુઅલ ડેટા એન્ટ્રીને દૂર કરો અને વધુ સારી ડેટા ટ્રેકિંગ અને વિશ્લેષણ માટે ચોક્કસ, "
"વાસ્તવિક સમય સમન્વય સુનિશ્ચિત કરો."

msgid "Free"
msgstr "મફત"

msgid "Formidable Forms Google Sheet Connector"
msgstr "ફોર્મિડેબલ ફોર્મ્સ ગૂગલ શીટ કનેક્ટર"

msgid ""
"Automatically sync Formidable Forms entries to Google Sheets. Manage leads, track "
"submissions, and simplify data reporting with real-time integration."
msgstr ""
"ફોર્મિડેબલ ફોર્મ્સના પ્રવેશોને ગૂગલ શીટ્સમાં આપોઆપ સમન્વયિત કરો. લીડ્સને સંચાલિત કરો, સબમિશન્સને "
"ટ્રેક કરો, અને વાસ્તવિક સમયના એકીકરણ સાથે ડેટા અહેવાલને સરળ બનાવો."

msgid "Fluent Forms Google Sheet Connector"
msgstr "ફ્લુએન્ટ ફોર્મ્સ ગૂગલ શીટ કનેક્ટર"

msgid ""
"Automatically sync Fluent Forms submissions to Google Sheets in real-time. Every "
"form entry is instantly added to your selected spreadsheet, helping you manage "
"leads, customer inquiries, and business data without manual export. Streamline "
"your workflow, improve reporting accuracy, and keep all submissions organized with "
"seamless Google Sheets integration."
msgstr ""
"ફ્લુએન્ટ ફોર્મ્સના સબમિશન્સને વાસ્તવિક સમયમાં ગૂગલ શીટ્સમાં આપોઆપ સમન્વયિત કરો. દરેક ફોર્મ પ્રવેશ "
"તરત જ તમારા પસંદ કરેલા સ્પ્રેડશીટમાં ઉમેરવામાં આવે છે, જે તમને મેન્યુઅલ નિકાસ વિના લીડ્સ, ગ્રાહક "
"પૂછપરછ અને વ્યવસાય ડેટાને સંચાલિત કરવામાં મદદ કરે છે. તમારા વર્કફ્લોને સરળ બનાવો, અહેવાલની "
"ચોકસાઈમાં સુધારો, અને સરળ ગૂગલ શીટ્સ એકીકરણ સાથે તમામ સબમિશન્સને ગોઠવો."

msgid "Elementor Forms Google Sheet Connector"
msgstr "એલિમેન્ટર ફોર્મ્સ ગૂગલ શીટ કનેક્ટર"

msgid ""
"Sync Elementor Forms with Google Sheets instantly. Automatically add new form "
"submissions to your spreadsheet, manage leads efficiently, and simplify reporting "
"with real-time data synchronization."
msgstr ""
"એલિમેન્ટર ફોર્મ્સને ગૂગલ શીટ્સ સાથે તરત જ સમન્વયિત કરો. આપોઆપ નવા ફોર્મ સબમિશન્સને તમારા "
"સ્પ્રેડશીટમાં ઉમેરો, લીડ્સને અસરકારક રીતે સંચાલિત કરો, અને વાસ્તવિક સમયના ડેટા સમન્વય સાથે "
"અહેવાલને સરળ બનાવો."

msgid "Avada Forms Google Sheet Connector"
msgstr "અવાડા ફોર્મ્સ ગૂગલ શીટ કનેક્ટર"

msgid ""
"Connect Avada Forms to Google Sheets and automatically transfer form entries to "
"your spreadsheet. Streamline lead management, automate data collection, and "
"improve business reporting with seamless integration."
msgstr ""
"અવાડા ફોર્મ્સને ગૂગલ શીટ્સ સાથે જોડો અને આપોઆપ ફોર્મ પ્રવેશોને તમારા સ્પ્રેડશીટમાં ટ્રાન્સફર કરો. "
"લીડ મેનેજમેન્ટને સરળ બનાવો, ડેટા એકત્રિત કરવા માટે ઓટોમેટ કરો, અને સરળ એકીકરણ સાથે વ્યવસાય "
"અહેવાલમાં સુધારો."

msgid "Available PRO Version"
msgstr "ઉપલબ્ધ PRO સંસ્કરણ"

msgid "Divi Forms Google Sheet Connector"
msgstr "ડિવી ફોર્મ્સ ગૂગલ શીટ કનેક્ટર"

msgid ""
"Integrate Divi Forms with Google Sheets and automatically sync submissions in real-"
"time. Store customer data securely, track inquiries efficiently, and eliminate "
"manual spreadsheet updates."
msgstr ""
"ડિવી ફોર્મ્સને ગૂગલ શીટ્સ સાથે એકીકૃત કરો અને આપોઆપ સબમિશન્સને વાસ્તવિક સમયમાં સમન્વયિત કરો. "
"ગ્રાહક ડેટાને સુરક્ષિત રીતે સંગ્રહિત કરો, પૂછપરછને અસરકારક રીતે ટ્રેક કરો, અને મેન્યુઅલ સ્પ્રેડશીટ "
"અપડેટ્સને દૂર કરો."

msgid "WP Core Google Sheet Connector"
msgstr "WP કોર ગૂગલ શીટ કનેક્ટર"

msgid ""
"Automatically send WordPress core data (like comments or custom submissions) to "
"Google Sheets. Simplify website data tracking, automate record keeping, and "
"centralize important information in one organized spreadsheet."
msgstr ""
"વર્ડપ્રેસ કોર ડેટા (જેમ કે ટિપ્પણો અથવા કસ્ટમ સબમિશન્સ) ને ગૂગલ શીટ્સમાં આપોઆપ મોકલો. વેબસાઇટ "
"ડેટા ટ્રેકિંગને સરળ બનાવો, રેકોર્ડ રાખવાની પ્રક્રિયાને ઓટોમેટ કરો, અને એક ગોઠવેલા સ્પ્રેડશીટમાં "
"મહત્વપૂર્ણ માહિતી કેન્દ્રિત કરો."

msgid "WooCommerce Google Sheet Connector"
msgstr "વૂકોમર્સ ગૂગલ શીટ કનેક્ટર"

msgid ""
"Sync WooCommerce orders with Google Sheets automatically. Store order details, "
"customer information, and transaction data in real-time for easy reporting, "
"accounting, and business analysis."
