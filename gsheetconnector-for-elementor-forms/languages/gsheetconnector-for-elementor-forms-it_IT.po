msgid ""
"Create, connect, manage, and monitor how your form submissions are automatically "
"synced to Google Sheets in real time."
msgstr ""
"Crea, collega, gestisci e monitora come le tue invii di moduli vengono "
"sincronizzati automaticamente con Google Sheets in tempo reale."

