msgid ""
"Sync Elementor Forms data with Google Sheets in real-time effortlessly and "
"accurately."
msgstr ""
"Sincronize os dados dos formulários do Elementor com o Google Sheets em tempo "
"real, de forma fácil e precisa."

msgid "Integration of Elementor Forms with Google Sheet"
msgstr "Integração dos Formulários do Elementor com o Google Sheet"

